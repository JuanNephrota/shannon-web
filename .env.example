# Shannon Web Configuration
#
# For local development:
#   cp .env.example .env
#   # (SHANNON_ROOT is optional — defaults to the bundled ./shannon under
#   # Docker, or ../ for `pnpm dev`.)
#
# For Docker deployment:
#   docker compose up -d                          # Web + Temporal
#   docker compose --profile worker up -d         # Include Shannon worker
#

# ============================================
# Authentication (required — first-run bootstrap)
# ============================================

# Initial admin user, created when no users exist yet.
# IMPORTANT: change ADMIN_PASSWORD before first real run.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Session secret for cookie signing. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=your-secure-random-string-here

# Session max age in milliseconds (default: 24 hours)
# SESSION_MAX_AGE=86400000

# ============================================
# Shannon engine (optional — bundle is vendored at ./shannon)
# ============================================

# Override if you want to point at a different Shannon checkout.
# Leave unset to use the bundled copy.
# SHANNON_ROOT=/path/to/other/shannon

# Temporal server address.
# Local dev: localhost:7233
# Docker:    handled automatically by docker-compose.yml
TEMPORAL_ADDRESS=localhost:7233

# API server port
PORT=3001

# Optional: override specific directories (defaults derived from SHANNON_ROOT)
# AUDIT_LOGS_DIR=/path/to/audit-logs
# CONFIGS_DIR=/path/to/configs

# Optional: override user / session storage paths
# USERS_FILE=/path/to/users.json
# SESSION_DB=/path/to/sessions.db

# ============================================
# LLM API Keys (required only for actually running pentests)
# ============================================
#
# The web UI boots without these — they're only needed when the worker
# executes a run. You can also set them via the Settings page post-login.
#
# DATA PRIVACY NOTE:
# All LLM providers are accessed via API endpoints (not playground/consumer).
# API usage has stronger privacy protections:
# - Anthropic API: does NOT train on API data
# - OpenAI API:    does NOT train on API data by default (since March 2023)
# - OpenRouter:    follows underlying provider policies
#
# For enterprise compliance, configure organization-level settings in each
# provider's dashboard to ensure explicit opt-out from any data usage.

# Anthropic API key (primary provider)
# ANTHROPIC_API_KEY=sk-ant-...

# Alternative LLM providers
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Optional: OpenAI Organization ID for enterprise privacy controls.
# Configure opt-out settings in OpenAI dashboard for this organization.
# OPENAI_ORG_ID=org-...

# ============================================
# Worker profile (only used with `docker compose --profile worker up`)
# ============================================

# Path to the target repository for a pentest.
# TARGET_REPO=/path/to/target/repo

# Router configuration for alternative LLM providers.
# ANTHROPIC_BASE_URL=http://router:3456
# ANTHROPIC_AUTH_TOKEN=
# ROUTER_DEFAULT=openai,gpt-4o

# Increase Claude Code's output-token cap for long reports.
CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
